# ─── Database (فقط PostgreSQL) ───────────────────────────────────
# محلی: Postgres روی localhost با پورت 5432 (docker compose پورت db را publish می‌کند)
DATABASE_URL=postgresql+asyncpg://anistito:anistito@localhost:5432/anistito
DATABASE_URL_SYNC=postgresql://anistito:anistito@localhost:5432/anistito
DATABASE_ECHO=false

# تست pytest (اختیاری): اگر خالی باشد همان anistito استفاده می‌شود — tests/conftest.py
# TEST_DATABASE_URL=postgresql+asyncpg://anistito:anistito@127.0.0.1:5432/anistito
# اجرای pytest بدون پاک کردن جداول در پایان: PYTEST_SKIP_DROP_ALL=1

# رمز کاربران دانشجوی دمو (AUTO-DEMO-*) در seed
DEMO_MATRIX_STUDENT_PASSWORD=demo_student_123

# اگر true و هیچ دانشجویی در DB نباشد، با استارت API همان دیتابیس با دمو پر می‌شود (برای Docker توصیه می‌شود)
SEED_DEMO_ON_STARTUP=false
SEED_DEMO_FULL_MATRIX=false

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Application ─────────────────────────────────────────────────
DEBUG=true
# CORS: در production دامنه‌های مجاز را با کاما بگذارید (نه *)
# CORS_ALLOW_ORIGINS=https://lms.psychoanalysis.ir,https://ims.psychoanalysis.ir
CORS_ALLOW_ORIGINS=*
APP_NAME=Anistito - Educational Automation System
APP_VERSION=1.0.0
# Production base URL (for links in SMS/email, etc.)
# APP_BASE_URL=https://bpms.psychoanalysis.ir/anistito

# ─── Auth ────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-a-real-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# مسئول اولیهٔ تیکت‌ها (نام کاربری). خالی = اولین کاربر staff فعال.
# TICKET_TRIAGE_USERNAME=staff1

# ─── SMS ─────────────────────────────────────────────────────────
# Options: "log" (فقط لاگ، بدون ارسال) | "mellipayamak" | "kavenegar"
SMS_PROVIDER=log
# OTP (ملی‌پیامک): متد SendOtp روی rest.payamak-panel.com — نام کاربری و رمز «وب‌سرویس» پنل (نه فقط توکن Bearer کنسول)
SMS_USERNAME=your_panel_username
SMS_PASSWORD=your_webservice_password
SMS_API_KEY=your-mellipayamak-api-token-here
# اگر SMS_PASSWORD خالی باشد، برای SendOtp از SMS_API_KEY به‌عنوان رمز استفاده می‌شود.
# شماره خط ارسال (الزامی برای SendOtp)
SMS_LINE_NUMBER=3000xxxx

# ورود دانشجو با موبایل (OTP): با SMS_PROVIDER=mellipayamak کد به شماره ارسال می‌شود.
# اگر true باشد فقط شماره‌هایی که در DB با نقش student ثبت شده‌اند کد می‌گیرند.
OTP_RESTRICT_TO_STUDENT_PHONES=false
# نمایش کد OTP در پاسخ API و روی صفحه ورود (برای توسعه؛ در production حتماً false)
OTP_SHOW_CODE_IN_UI=true

# ─── External integration (LMS / وب‌هوک اکشن‌های متادیتا) ───────────
# اگر خالی باشد، فقط روی process_instances.context_data.integration_events ثبت می‌شود.
LMS_INTEGRATION_WEBHOOK_URL=
LMS_INTEGRATION_SECRET=

# ─── Payment ─────────────────────────────────────────────────────
# Options: "mock" | "saman" | "zibal"
PAYMENT_PROVIDER=mock
# Production: https://bpms.psychoanalysis.ir/anistito/api/payment/callback
PAYMENT_CALLBACK_URL=http://localhost:3000/api/payment/callback

# Saman (SEP)
SEP_TERMINAL_ID=
SEP_PASSWORD=

# Zibal
ZIBAL_MERCHANT=
ZIBAL_SANDBOX=true

# ─── Email ───────────────────────────────────────────────────────
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_FROM=noreply@anistito.ir

# ─── SLA ─────────────────────────────────────────────────────────
SLA_CHECK_INTERVAL_SECONDS=300

# ─── تریگرهای تقویمی (payment_timeout، یادآوری مرخصی، session_time_reached، …) ─
CALENDAR_TRIGGERS_ENABLED=true
CALENDAR_TRIGGER_INTERVAL_SECONDS=300
