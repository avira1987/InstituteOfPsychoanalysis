# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./anistito.db
DATABASE_URL_SYNC=sqlite:///./anistito.db
DATABASE_ECHO=false

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Application ─────────────────────────────────────────────────
DEBUG=true
APP_NAME=Anistito - Educational Automation System
APP_VERSION=1.0.0
# Production base URL (for links in SMS/email, etc.)
# APP_BASE_URL=https://bpms.psychoanalysis.ir/anistito

# ─── Auth ────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-a-real-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── SMS ─────────────────────────────────────────────────────────
# Options: "log" (فقط لاگ، بدون ارسال) | "mellipayamak" | "kavenegar"
SMS_PROVIDER=log
SMS_API_KEY=your-mellipayamak-api-token-here
# شماره خط برای mellipayamak (از پنل melipayamak دریافت کنید)
SMS_LINE_NUMBER=3000xxxx

# ─── Payment ─────────────────────────────────────────────────────
# Options: "mock" | "saman" | "zibal"
PAYMENT_PROVIDER=mock
# Production: https://bpms.psychoanalysis.ir/anistito/api/payment/callback
PAYMENT_CALLBACK_URL=http://localhost:8000/api/payment/callback

# Saman (SEP)
SEP_TERMINAL_ID=
SEP_PASSWORD=

# Zibal
ZIBAL_MERCHANT=
ZIBAL_SANDBOX=true

# ─── Email ───────────────────────────────────────────────────────
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_FROM=noreply@anistito.ir

# ─── SLA ─────────────────────────────────────────────────────────
SLA_CHECK_INTERVAL_SECONDS=300
