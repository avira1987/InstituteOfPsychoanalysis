# ─── Database (فقط PostgreSQL) ───────────────────────────────────
# محلی: Postgres روی localhost با پورت 5432 (docker compose پورت db را publish می‌کند)
DATABASE_URL=postgresql+asyncpg://anistito:anistito@localhost:5432/anistito
DATABASE_URL_SYNC=postgresql://anistito:anistito@localhost:5432/anistito
DATABASE_ECHO=false

# تست pytest (اختیاری): اگر خالی باشد همان anistito استفاده می‌شود — tests/conftest.py
# TEST_DATABASE_URL=postgresql+asyncpg://anistito:anistito@127.0.0.1:5432/anistito
# اجرای pytest بدون پاک کردن جداول در پایان: PYTEST_SKIP_DROP_ALL=1

# رمز کاربران دانشجوی دمو (AUTO-DEMO-*) در seed
DEMO_MATRIX_STUDENT_PASSWORD=demo_student_123

# اگر true و هیچ دانشجویی در DB نباشد، با استارت API همان دیتابیس با دمو پر می‌شود (برای Docker توصیه می‌شود)
SEED_DEMO_ON_STARTUP=false
SEED_DEMO_FULL_MATRIX=false

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Application ─────────────────────────────────────────────────
DEBUG=true
# CORS: در production دامنه‌های مجاز را با کاما بگذارید (نه *)
# CORS_ALLOW_ORIGINS=https://lms.psychoanalysis.ir,https://ims.psychoanalysis.ir
CORS_ALLOW_ORIGINS=*
APP_NAME=Anistito - Educational Automation System
APP_VERSION=1.0.0
# Production base URL (for links in SMS/email, etc.)
# APP_BASE_URL=https://bpms.psychoanalysis.ir/anistito

# ─── Auth ────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-a-real-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# مسئول اولیهٔ تیکت‌ها (نام کاربری). خالی = اولین کاربر staff فعال.
# TICKET_TRIAGE_USERNAME=staff1

# ─── SMS ─────────────────────────────────────────────────────────
# Options: "log" (فقط لاگ، بدون ارسال) | "mellipayamak" | "kavenegar"
SMS_PROVIDER=log
# ملی‌پیامک — روی rest.payamak-panel.com پارامتر password می‌تواند «رمز وب‌سرویس» یا همان APIKey پنل باشد (راهنمای پنل: APIKey به‌جای Password).
# ترجیح: SMS_USERNAME + (SMS_PASSWORD یا خالی با SMS_API_KEY=همان APIKey) + SMS_LINE_NUMBER → SendOtp / SendSMS
# اگر SMS_USERNAME خالی باشد: فقط SMS_API_KEY (توکن کنسول) → POST .../api/send/simple/{token}
# نام کاربری پنل؛ اغلب شماره موبایل ۱۰ رقمی (مثال: 9032054361)
SMS_USERNAME=
# رمز وب‌سرویس؛ یا خالی + SMS_API_KEY=APIKey پنل → همان APIKey به‌عنوان password در rest
SMS_PASSWORD=
SMS_API_KEY=your-mellipayamak-api-key-or-console-token-here
# شماره خط ارسال (الزامی برای هر دو مسیر)
SMS_LINE_NUMBER=3000xxxx

# ورود دانشجو با موبایل (OTP): با SMS_PROVIDER=mellipayamak کد به شماره ارسال می‌شود.
# اگر true باشد فقط شماره‌هایی که در DB با نقش student ثبت شده‌اند کد می‌گیرند.
# برای مسیر «ورود با پیامک سپس تکمیل ثبت‌نام در /panel/complete-registration» باید false باشد تا شمارهٔ جدید هم OTP بگیرد.
OTP_RESTRICT_TO_STUDENT_PHONES=false
# نمایش کد OTP در پاسخ API و روی صفحه ورود (برای توسعه؛ در production حتماً false)
OTP_SHOW_CODE_IN_UI=true

# ─── External integration (LMS / وب‌هوک اکشن‌های متادیتا) ───────────
# اگر خالی باشد، فقط روی process_instances.context_data.integration_events ثبت می‌شود.
LMS_INTEGRATION_WEBHOOK_URL=
LMS_INTEGRATION_SECRET=

# ─── الوکام (کلاس آنلاین) ───────────────────────────────────────
# ALOCOM_ENABLED=false
# ALOCOM_API_BASE=https://pnlapi.alocom.co
# ALOCOM_USERNAME=
# ALOCOM_PASSWORD=
# ALOCOM_DEFAULT_AGENT_SERVICE_ID=0
# در صورت 404، مسیرها را از مستند رسمی تنظیم کنید؛ نمونهٔ پیش‌فرض ممکن است با نسخه شما فرق کند.
# ALOCOM_PATH_LOGIN=/api/v1/auth/login
# ALOCOM_PATH_CREATE_EVENT=/api/v1/agent/event/store
# ALOCOM_PATH_REGISTER_IN_EVENT=/api/v1/agent/event/{event_id}/register-user
# ALOCOM_PATH_CREATE_USER=/api/v1/agent/users/store
# ALOCOM_FALLBACK_TO_UI_HINTS=true

# ─── Payment ─────────────────────────────────────────────────────
# Options: "mock" | "saman" | "zibal"
# مبلغ در API پرداخت و شاپرک به ریال است؛ پیش‌فاکتور داخلی (invoice_amount) به تومان — UI از payment_amount_rial استفاده می‌کند.
# جلسهٔ اول فرایند آغاز درمان (اگر در context نباشد؛ پیش‌فرض در app/config.py هم هست)
# START_THERAPY_FIRST_SESSION_FEE_RIAL=10000000
# جلسه اضافی درمان آموزشی (ریال) — extra_session
# EXTRA_SESSION_FEE_RIAL=7500000
PAYMENT_PROVIDER=mock
# Production: باید دقیقاً با آدرس ثبت‌شده در پنل سپ یکسان باشد (GET و POST هر دو پشتیبانی می‌شوند)
PAYMENT_CALLBACK_URL=http://localhost:3000/api/payment/callback
# بعد از کال‌بک، مرورگر به APP_BASE_URL + این مسیر ریدایرکت می‌شود (پیش‌فرض: پنل دانشجو)
# PAYMENT_RETURN_PATH=/panel/portal/student

# Saman (SEP) — مقادیر واقعی را فقط در .env محلی/سرور بگذارید، نه در git
SEP_TERMINAL_ID=
SEP_PASSWORD=

# Zibal
ZIBAL_MERCHANT=
ZIBAL_SANDBOX=true

# ─── Email ───────────────────────────────────────────────────────
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_FROM=noreply@anistito.ir

# ─── SLA ─────────────────────────────────────────────────────────
SLA_CHECK_INTERVAL_SECONDS=300

# ─── تریگرهای تقویمی (payment_timeout، یادآوری مرخصی، session_time_reached، …) ─
CALENDAR_TRIGGERS_ENABLED=true
CALENDAR_TRIGGER_INTERVAL_SECONDS=300
# یادآوری پیامکی مصاحبهٔ پذیرش (ساعت قبل از شروع اسلات رزروشده)
INTERVIEW_REMINDER_HOURS_BEFORE=2

# مرخصی آموزشی — یادآوری بازگشت و مهلت اعلام ثبت‌نام ترم، از زمان فعال‌سازی وقفه در سامانه (روز) محاسبه می‌شود؛ تاریخ شمس ثابت در کد نیست.
EDUCATIONAL_LEAVE_RETURN_REMINDER_OFFSET_DAYS=90
EDUCATIONAL_LEAVE_RETURN_DEADLINE_AFTER_REMINDER_DAYS=30
