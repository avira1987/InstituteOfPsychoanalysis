# Database
DATABASE_URL=postgresql+asyncpg://anistito:anistito@localhost:5432/anistito
DATABASE_URL_SYNC=postgresql://anistito:anistito@localhost:5432/anistito
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# Application
DEBUG=true
APP_NAME=Anistito - Educational Automation System
