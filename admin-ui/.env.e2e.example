# کپی به .env.e2e و مقادیر را تنظیم کنید (اختیاری؛ در CI این فایل بارگذاری نمی‌شود — فقط متغیرهای runner)

# آدرس فرانت‌اند (Vite) — همان مقدار در Playwright baseURL
E2E_BASE_URL=http://127.0.0.1:5173

# بک‌اند باید در دسترس باشد (پروکسی Vite: معمولاً 127.0.0.1:3000)

# اگر Vite را جدا اجرا می‌کنید:
# E2E_SKIP_WEBSERVER=1

# مرورگر: محلی پیش‌فرض msedge؛ CI پیش‌فرض Chromium باندل
# E2E_BROWSER_CHANNEL=bundled
# E2E_BROWSER_CHANNEL=msedge

# headless پیش‌فرض؛ برای پنجرهٔ مرورگر: E2E_HEADED=1

# گزارش HTML: مسیر خروجی (پیش‌فرض playwright-report)
# E2E_HTML_REPORT_DIR=playwright-report

# توقف اجرا پس از N شکست (در CI پیش‌فرض ۱). اجرای کامل همهٔ تست‌ها: E2E_MAX_FAILURES=0
# E2E_MAX_FAILURES=1

# موازی‌سازی (در CI اگر خالی باشد معمولاً ۱ worker)
# E2E_WORKERS=1

# ویدیوی خطا نیاز به npx playwright install ffmpeg
# E2E_VIDEO=1

# کاربر مدیر برای تست‌هایی که API ادمین می‌خواهند (مثلاً conditional-therapy-attendance)
# همان کاربری که API با آن بالا می‌آید (پیش‌فرض: admin / admin123 اگر در DB ساخته شده باشد)
# E2E_ADMIN_USERNAME=admin
# E2E_ADMIN_PASSWORD=admin123
