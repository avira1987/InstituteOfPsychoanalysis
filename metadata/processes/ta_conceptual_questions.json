  "forms": [
    {"code": "conceptual_question_template", "name_fa": "قالب سوال تستی‌مفهومی", "used_in_state": "ta_upload", "fields": [{"name": "question_1", "label_fa": "سوال ۱", "type": "file_upload"}, {"name": "question_2", "label_fa": "سوال ۲", "type": "file_upload"}, {"name": "question_3", "label_fa": "سوال ۳", "type": "file_upload"}]}
  ]
