    {"code": "upload_late", "name_fa": "تاخیر آپلود — تخلف ثبت", "type": "intermediate", "assigned_role": "system"},
    {"code": "instructor_review", "name_fa": "بررسی توسط مدرس", "type": "intermediate", "assigned_role": "instructor", "sla_days": 4},
    {"code": "question_rejected", "name_fa": "سوال رد شد — اصلاح ۲۴ ساعته", "type": "intermediate", "assigned_role": "teaching_assistant"},
    {"code": "questions_approved", "name_fa": "تایید — آرشیو و ۲ نمره", "type": "terminal", "assigned_role": "system"}
