    {"from": "first_defense_held", "to": "defense_passed", "trigger": "all_grades_ab", "description_fa": "همه داوران A یا B — PASS"},
    {"from": "first_defense_held", "to": "revision_required", "trigger": "any_grade_cdf", "description_fa": "حداقل یک داور C/D/F — ارسال SMS مهلت ۲ هفته اصلاحات"},
    {"from": "revision_required", "to": "revision_upload", "trigger": "revision_uploaded", "required_role": "student", "description_fa": "دانشجو فایل اصلاح‌شده را آپلود کرد"},
    {"from": "revision_required", "to": "revision_delay_violation", "trigger": "revision_sla_breach", "description_fa": "عدم آپلود در مهلت ۲ هفته — گزارش تخلف به کمیته نظارت"},
    {"from": "revision_upload", "to": "second_defense_held", "trigger": "second_defense_scheduled", "required_role": "education_committee", "description_fa": "ثبت زمان دفاع مجدد (همان داوران) — ارسال SMS"},
    {"from": "second_defense_held", "to": "defense_passed", "trigger": "final_grades_ab", "description_fa": "نمره نهایی A یا B — PASS"},
    {"from": "second_defense_held", "to": "defense_failed", "trigger": "final_grades_cdf", "description_fa": "نمره نهایی C/D/F — FAIL (مردود)"}
  ],
