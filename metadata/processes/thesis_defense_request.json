    "name_en": "Thesis Defense Registration Request",
    "number": 70,
    "description": "فاز نهایی مسیر تحصیلی. دروازه‌بان با ۴ شرط: ۶۷ واحد با معدل B، ۷۵۰ ساعت تجربه بالینی، ۱۵۰ ساعت سوپرویژن فردی، ۲۵۰ ساعت درمان آموزشی. پیش‌نیاز: تیک تکمیل پایان‌نامه توسط مدرس درس مقاله‌نویسی. غربالگری: کمیته پیشرفت (تایید/نیاز به اصلاح/رد گزارش سایکوتیک)، کمیته نظارت (مجوز دفاع)، کمیته آموزش (انتخاب داوران و زمان، محرمانگی نام داوران تا روز دفاع). A/B = PASS؛ C/D/F = نیاز به اصلاح و دفاع مجدد. مهلت اصلاحات ۲ هفته؛ دفاع مجدد با همان داوران. نمره نهایی A/B = PASS، C/D/F = FAIL.",
    "initial_state": "eligibility_check",
    "initial_role": "student",
    "requires_form": true
  },
  "states": [
    {"code": "eligibility_check", "name_fa": "بررسی شروط چهارگانه و بارگذاری گزارش سایکوتیک", "type": "initial", "assigned_role": "student"},
