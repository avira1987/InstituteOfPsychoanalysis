        {"type": "scheduled_notification", "notification_type": "sms", "template": "interview_reminder_interviewer_inperson", "recipients": ["interviewer"], "schedule": "2_hours_before_interview", "condition": "interview_type == 'in_person'", "description_fa": "یادآوری ۲ ساعت قبل به مصاحبه‌کننده — حضوری"}
