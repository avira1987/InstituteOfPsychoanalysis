    {"code": "interview_payment", "name_fa": "در انتظار پرداخت هزینه مصاحبه", "type": "intermediate", "assigned_role": "applicant", "metadata": {"student_task_fa": "باید پرداخت هزینهٔ مصاحبه را در درگاه تکمیل کنید؛ در صورت خطا دوباره تلاش کنید تا تأیید پرداخت ثبت شود."}},
