    {"code": "result_single_course", "name_fa": "نتیجه: پذیرش تک‌درس", "type": "intermediate", "assigned_role": "system", "metadata": {"admission_type": "single_course", "allowed_courses": ["تئوری روانکاوی ۱"], "payment_restriction": "cash_only", "student_task_fa": "پذیرش شما محدود به درس(های) اعلام‌شده است؛ مدارک و پرداخت را طبق همین محدودیت و راهنمای پنل انجام دهید (در صورت الزام، پرداخت فقط نقدی)."}},
    {"code": "result_full_admission", "name_fa": "نتیجه: پذیرش کامل (بدون شرط)", "type": "intermediate", "assigned_role": "system", "metadata": {"admission_type": "full", "allowed_courses": "1-5", "student_task_fa": "پذیرش کامل دریافت شده است؛ مرحلهٔ بعد را طبق پنل (مدارک، انتخاب دروس، پرداخت) پیش ببرید."}},
    {"code": "rejected", "name_fa": "رد شده — مسدودیت ثبت‌نام آینده", "type": "terminal", "assigned_role": "system", "metadata": {"student_task_fa": "این مسیر در وضعیت رد قرار گرفته است؛ برای پرسش، از طریق تیکت یا تماس با پذیرش پیگیری کنید."}},
    {"code": "documents_upload", "name_fa": "در انتظار آپلود مدارک و تعهدنامه", "type": "intermediate", "assigned_role": "applicant", "sla_hours": 48, "metadata": {"student_task_fa": "باید مدارک و تعهدنامهٔ خواسته‌شده را در همین مرحله از پنل بارگذاری کنید و ثبت را تکمیل کنید."}},
    {"code": "documents_review", "name_fa": "بررسی مدارک توسط مسئول پذیرش", "type": "intermediate", "assigned_role": "admissions_officer", "metadata": {"student_task_fa": "در این مرحله بررسی توسط پذیرش انجام می‌شود؛ اگر فرمی باز است تکمیل کنید؛ در غیر این صورت بعداً همین صفحه را تازه کنید."}},
    {"code": "documents_incomplete", "name_fa": "مدارک ناقص — در انتظار تکمیل", "type": "intermediate", "assigned_role": "applicant", "sla_hours": 48, "metadata": {"student_task_fa": "باید نقص‌های اعلام‌شده را برطرف و مدارک را دوباره بارگذاری کنید."}},
    {"code": "credentials_created", "name_fa": "حساب کاربری ایجاد شد — ارسال اطلاعات ورود", "type": "intermediate", "assigned_role": "system", "metadata": {"student_task_fa": "اطلاعات ورود از سمت آموزش ارسال می‌شود؛ سپس مرحلهٔ انتخاب دروس در LMS برای شما فعال می‌شود — همین صفحه را بعداً تازه کنید."}},
    {"code": "course_selection", "name_fa": "انتخاب دروس مجاز در LMS", "type": "intermediate", "assigned_role": "student", "metadata": {"student_task_fa": "باید دروس مجاز را در LMS طبق لیست اعلام‌شده انتخاب و ثبت کنید؛ اگر دکمهٔ مرحلهٔ بعد در پنل فعال بود پس از ثبت دروس آن را بزنید."}},
    {"code": "payment", "name_fa": "پرداخت شهریه (نقدی یا اقساط)", "type": "intermediate", "assigned_role": "student", "metadata": {"student_task_fa": "باید شهریه را نقدی یا حداکثر در ۴ قسط طبق راهنمای پرداخت همین مرحله تسویه کنید تا ثبت‌نام نهایی شود."}},
    {"code": "registration_complete", "name_fa": "ثبت‌نام نهایی — دروس ثبت و لینک کلاس فعال", "type": "terminal", "assigned_role": "system", "metadata": {"student_task_fa": "ثبت‌نام این دوره در این فرایند تکمیل شده است؛ برای مراحل بعدی آموزشی، مسیرهای دیگر در پنل را ببینید."}},
    {"code": "installment_overdue", "name_fa": "قسط معوق — بلاک حضور و غیاب", "type": "intermediate", "assigned_role": "system", "metadata": {"student_task_fa": "تسویهٔ قسط معوق را پیگیری کنید؛ تا زمان رفع بلاک، طبق اعلام آموزش در کلاس‌ها حضور ثبت نمی‌شود."}}
  ],
