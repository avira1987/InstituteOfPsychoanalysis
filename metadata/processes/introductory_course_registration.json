      "fields": [
        {"name": "selected_timeslot", "label_fa": "انتخاب وقت مصاحبه", "type": "radio_list", "source": "available_interview_slots", "format": "{date} ساعت {time} — {interview_type}", "required": true}
      ]
    },
    {
      "code": "interview_result_form",
      "name_fa": "فرم ثبت نتیجه مصاحبه (محرمانه)",
      "used_in_state": "interview_completed",
      "confidential": true,
      "visible_to": ["interviewer", "admissions_officer", "admin"],
      "note_fa": "این فرم محرمانه است و برای دانشجو قابل مشاهده نیست",
      "fields": [
        {
          "name": "interview_result",
          "label_fa": "نتیجه مصاحبه",
          "type": "radio",
          "options": [
            {"value": "conditional_therapy", "label_fa": "پذیرش مشروط به شروع درمان شخصی"},
            {"value": "single_course", "label_fa": "فقط مجاز به اخذ درس تئوری روانکاوی ۱"},
            {"value": "full_admission", "label_fa": "پذیرش کامل (بدون شرط)"},
            {"value": "rejected", "label_fa": "رد درخواست"}
          ],
          "required": true
        },
        {
          "name": "allowed_course_count",
          "label_fa": "تعداد دروس مجاز",
          "type": "number",
          "min": 1,
