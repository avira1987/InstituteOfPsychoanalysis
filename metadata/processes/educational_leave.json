{
  "process": {
    "code": "educational_leave",
    "name_fa": "مرخصی آموزشی موقت از ثبت‌نام در کلاس‌ها",
    "name_en": "Educational Leave of Absence",
    "description": "فرایند درخواست و مدیریت مرخصی آموزشی موقت دانشجویان از ثبت‌نام در کلاس‌ها",
    "initial_state": "request_form"
  },
  "states": [
    {"code": "request_form", "name_fa": "ثبت درخواست اولیه", "type": "initial", "assigned_role": "student"},
    {"code": "committee_review", "name_fa": "بررسی کمیته پیشرفت", "type": "intermediate", "assigned_role": "progress_committee", "sla_hours": 168},
    {"code": "session_scheduled", "name_fa": "جلسه تنظیم شد", "type": "intermediate", "assigned_role": "progress_committee"},
    {"code": "committee_decision", "name_fa": "تصمیم‌گیری کمیته", "type": "intermediate", "assigned_role": "progress_committee"},
    {"code": "approved_non_intern", "name_fa": "تایید - غیر انترن", "type": "intermediate", "assigned_role": "system"},
    {"code": "approved_intern_1term", "name_fa": "تایید - انترن ۱ ترم", "type": "intermediate", "assigned_role": "system"},
    {"code": "approved_intern_2term", "name_fa": "تایید - انترن ۲ ترم", "type": "intermediate", "assigned_role": "system"},
    {"code": "rejected", "name_fa": "رد درخواست", "type": "terminal", "assigned_role": "system"},
    {"code": "on_leave", "name_fa": "در وقفه تحصیلی", "type": "intermediate", "assigned_role": "system"},
    {"code": "return_reminder_sent", "name_fa": "یادآوری بازگشت ارسال شد", "type": "intermediate", "assigned_role": "system", "sla_hours": 336},
    {"code": "returned", "name_fa": "بازگشت به تحصیل", "type": "terminal", "assigned_role": "system"},
    {"code": "violation_registered", "name_fa": "ثبت تخلف عدم بازگشت", "type": "terminal", "assigned_role": "system"}
  ],
  "transitions": [
    {
      "from": "request_form",
      "to": "committee_review",
      "trigger": "student_submitted",
      "required_role": "student",
      "actions": [
        {"type": "warn_if", "condition": "student.is_intern AND leave_terms == 2", "message_fa": "هشدار: در صورت ۲ ترم وقفه، وضعیت انترنی لغو خواهد شد"}
      ]
    },
    {
      "from": "committee_review",
      "to": "session_scheduled",
      "trigger": "committee_set_meeting",
      "required_role": "progress_committee"
    },
    {
      "from": "session_scheduled",
      "to": "committee_decision",
      "trigger": "meeting_held",
      "required_role": "progress_committee"
    },
    {
      "from": "committee_decision",
      "to": "rejected",
      "trigger": "committee_rejected",
      "required_role": "progress_committee",
      "actions": [
        {"type": "notification", "notification_type": "sms", "template": "leave_rejected", "recipients": ["student"]}
      ]
    },
    {
      "from": "committee_decision",
      "to": "approved_non_intern",
      "trigger": "committee_approved",
      "required_role": "progress_committee",
      "conditions": ["is_not_intern"],
      "actions": [
        {"type": "notification", "notification_type": "sms", "template": "leave_approved", "recipients": ["student"]}
      ]
    },
    {
      "from": "committee_decision",
      "to": "approved_intern_1term",
      "trigger": "committee_approved",
      "required_role": "progress_committee",
      "conditions": ["is_intern", "leave_terms_eq_1"],
      "priority": 1,
      "actions": [
        {"type": "notification", "notification_type": "sms", "template": "leave_approved_intern_1", "recipients": ["student"]}
      ]
    },
    {
      "from": "committee_decision",
      "to": "approved_intern_2term",
      "trigger": "committee_approved",
      "required_role": "progress_committee",
      "conditions": ["is_intern", "leave_terms_eq_2"],
      "priority": 2,
      "actions": [
        {"type": "release_supervisor_slot"},
        {"type": "start_process", "process_code": "patient_referral"},
        {"type": "notification", "notification_type": "sms", "template": "leave_approved_intern_2_warning", "recipients": ["student"]}
      ]
    },
    {
      "from": "approved_non_intern",
      "to": "on_leave",
      "trigger": "leave_activated",
      "actions": [
        {"type": "suspend_class_registration"}
      ]
    },
    {
      "from": "approved_intern_1term",
      "to": "on_leave",
      "trigger": "leave_activated",
      "actions": [
        {"type": "suspend_class_registration"}
      ]
    },
    {
      "from": "approved_intern_2term",
      "to": "on_leave",
      "trigger": "leave_activated",
      "actions": [
        {"type": "suspend_class_registration"},
        {"type": "revoke_intern_status"}
      ]
    },
    {
      "from": "on_leave",
      "to": "return_reminder_sent",
      "trigger": "send_return_reminder",
      "actions": [
        {"type": "notification", "notification_type": "sms", "template": "return_reminder", "recipients": ["student"]}
      ]
    },
    {
      "from": "return_reminder_sent",
      "to": "returned",
      "trigger": "student_returned",
      "actions": [
        {"type": "reactivate_class_registration"}
      ]
    },
    {
      "from": "return_reminder_sent",
      "to": "violation_registered",
      "trigger": "return_deadline_passed",
      "actions": [
        {"type": "register_violation", "violation_type": "no_return_from_leave"},
        {"type": "notification", "notification_type": "sms", "template": "violation_no_return", "recipients": ["student", "admin"]}
      ]
    }
  ]
}
