{
  "process": {
    "code": "ta_track_change",
    "name_fa": "تغییر یا اضافه کردن رسته کمک‌مدرس",
    "name_en": "TA Track Change or Add",
    "number": 51,
    "description": "پیش‌شرط: فرایند ارتقا به کمک‌مدرس با موفقیت. دو گزینه: اضافه کردن رسته (حفظ فعلی + جدید) یا تغییر رسته (حذف فعلی + جایگزین). هماهنگی خارج از سیستم. جلسه با کمیته دروس. موافقت/عدم موافقت. در صورت موافقت: اعمال تغییر یا اضافه در LMS.",
    "initial_state": "ta_click",
    "initial_role": "teaching_assistant"
  },
  "states": [
    {"code": "ta_click", "name_fa": "کلیک کمک‌مدرس", "type": "initial", "assigned_role": "teaching_assistant"},
    {"code": "path_selected", "name_fa": "انتخاب مسیر (تغییر/اضافه)", "type": "intermediate", "assigned_role": "teaching_assistant"},
    {"code": "course_committee_review", "name_fa": "هماهنگی و جلسه کمیته دروس", "type": "intermediate", "assigned_role": "course_committee_scientific"},
    {"code": "rejected", "name_fa": "عدم موافقت", "type": "terminal", "assigned_role": "system"},
    {"code": "track_applied", "name_fa": "رسته اعمال شد", "type": "terminal", "assigned_role": "system"}
  ],
  "transitions": [
    {"from": "ta_click", "to": "path_selected", "trigger": "path_chosen", "required_role": "teaching_assistant", "description_fa": "تغییر رسته یا اضافه کردن رسته — Radio"},
    {"from": "path_selected", "to": "course_committee_review", "trigger": "request_sent", "description_fa": "درخواست به پورتال کمیته دروس"},
    {"from": "course_committee_review", "to": "rejected", "trigger": "rejected", "required_role": "course_committee_scientific", "description_fa": "عدم موافقت — پایان"},
    {"from": "course_committee_review", "to": "track_applied", "trigger": "approved", "required_role": "course_committee_scientific", "description_fa": "موافقت — انتخاب رسته جدید، اعمال تغییر یا اضافه", "actions": [{"type": "notification", "notification_type": "sms", "template": "ta_track_meeting_scheduled", "recipients": ["student", "course_committee_scientific"]}]}
  ],
  "forms": [
    {"code": "ta_track_path", "name_fa": "انتخاب مسیر", "used_in_state": "ta_click", "fields": [{"name": "path", "type": "radio", "options": [{"value": "add", "label_fa": "اضافه کردن رسته (حفظ فعلی)"}, {"value": "change", "label_fa": "تغییر رسته (حذف فعلی)"}]}]},
    {"code": "ta_track_meeting", "name_fa": "ثبت زمان جلسه", "used_in_state": "course_committee_review", "fields": [{"name": "meeting_date", "type": "date_picker"}, {"name": "meeting_time", "type": "time_picker"}, {"name": "meeting_type", "type": "radio", "options": [{"value": "in_person", "label_fa": "حضوری"}, {"value": "online", "label_fa": "آنلاین"}]}]},
    {"code": "ta_track_result", "name_fa": "نتیجه و انتخاب رسته", "used_in_state": "course_committee_review", "fields": [{"name": "result", "type": "radio", "options": [{"value": "approve", "label_fa": "موافقت"}, {"value": "reject", "label_fa": "عدم موافقت"}]}, {"name": "new_tracks", "label_fa": "رسته(های) جدید", "type": "multi_select", "visible_when": "result == 'approve'"}]}
  ]
}
