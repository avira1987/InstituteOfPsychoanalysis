{
  "process": {
    "code": "comprehensive_course_registration",
    "name_fa": "فرایند ثبت‌نام در دوره جامع",
    "name_en": "Comprehensive Course Registration",
    "number": 35,
    "description": "فرایند چندمرحله‌ای ثبت‌نام در دوره جامع شامل: بررسی پرونده توسط کمیته نظارت، بررسی معدل توسط مسئول اجرایی و تصمیم مسئول علمی کمیته پیشرفت، بارگذاری گزارش تجربه شخصی، زمان‌بندی و پرداخت مصاحبه، برگزاری مصاحبه و اعلام نتیجه (پذیرش / رد قطعی / رد با پیشنهاد)، و نهایتاً ثبت‌نام و پرداخت دروس ترم ۳ برای پذیرفته‌شدگان. دلایل رد محرمانه و فقط در پورتال پذیرش ثبت می‌شود.",
    "initial_state": "application_submitted",
    "prerequisites": ["all_10_introductory_courses_passed"],
    "interview_document_template": {
      "source": "Dr. Moradi",
      "font": "B Nazanin",
      "font_size": 14,
      "type": "personal_experience_report"
    },
    "acceptance_conditions": {
      "therapy_requirement": "حداقل ۲ بار در هفته درمان شخصی الزامی",
      "course_requirement": "تمامی دروس ترم جامع الزامی"
    }
  },
  "states": [
    {"code": "application_submitted", "name_fa": "ثبت درخواست ورود به دوره جامع", "type": "initial", "assigned_role": "student"},
    {"code": "supervision_committee_review", "name_fa": "بررسی پرونده توسط کمیته نظارت", "type": "intermediate", "assigned_role": "supervision_committee", "sla_days": 2},
    {"code": "supervision_rejected", "name_fa": "رد توسط کمیته نظارت", "type": "terminal", "assigned_role": "system"},
    {"code": "executive_review", "name_fa": "بررسی پرونده و معدل توسط مسئول اجرایی کمیته پیشرفت", "type": "intermediate", "assigned_role": "progress_committee", "sla_days": 2},
    {"code": "scientific_review", "name_fa": "تصمیم‌گیری مسئول علمی کمیته پیشرفت", "type": "intermediate", "assigned_role": "progress_committee", "sla_days": 2},
    {"code": "scientific_rejected", "name_fa": "رد توسط مسئول علمی کمیته پیشرفت", "type": "terminal", "assigned_role": "system"},
    {"code": "document_upload", "name_fa": "بارگذاری گزارش تجربه شخصی", "type": "intermediate", "assigned_role": "student"},
    {"code": "interview_scheduled", "name_fa": "انتخاب زمان مصاحبه", "type": "intermediate", "assigned_role": "student"},
    {"code": "interview_payment", "name_fa": "پرداخت هزینه مصاحبه", "type": "intermediate", "assigned_role": "student"},
    {"code": "interview_completed", "name_fa": "مصاحبه انجام شده — در انتظار نتیجه", "type": "intermediate", "assigned_role": "progress_committee"},
    {"code": "result_accepted", "name_fa": "پذیرفته شده", "type": "intermediate", "assigned_role": "system"},
    {"code": "result_rejected", "name_fa": "رد قطعی", "type": "terminal", "assigned_role": "system"},
    {"code": "result_rejected_with_suggestion", "name_fa": "رد همراه با پیشنهاد", "type": "terminal", "assigned_role": "system"},
    {"code": "course_display", "name_fa": "نمایش دروس ترم ۳ (اول جامع)", "type": "intermediate", "assigned_role": "student"},
    {"code": "payment", "name_fa": "پرداخت شهریه (نقدی یا اقساط)", "type": "intermediate", "assigned_role": "student"},
    {"code": "registration_complete", "name_fa": "ثبت‌نام نهایی انجام شد", "type": "terminal", "assigned_role": "system"}
  ],
  "transitions": [
    {
      "from": "application_submitted",
      "to": "supervision_committee_review",
      "trigger": "application_submitted",
      "required_role": "student",
      "conditions": ["all_10_introductory_courses_passed"],
      "description_fa": "دانشجو درخواست ورود به دوره جامع را ثبت کرد — ارسال به کمیته نظارت",
      "actions": [
        {"type": "notification", "notification_type": "in_app", "template": "comprehensive_application_received", "recipients": ["supervision_committee"]}
      ]
    },
    {
      "from": "supervision_committee_review",
      "to": "executive_review",
      "trigger": "supervision_approved",
      "required_role": "supervision_committee",
      "description_fa": "کمیته نظارت پرونده را تایید کرد — ارسال به مسئول اجرایی کمیته پیشرفت",
      "actions": [
        {"type": "notification", "notification_type": "sms", "template": "file_forwarded_to_executive", "recipients": ["progress_committee"]}
      ]
    },
    {
      "from": "supervision_committee_review",
      "to": "supervision_rejected",
      "trigger": "supervision_rejected",
      "required_role": "supervision_committee",
      "description_fa": "کمیته نظارت پرونده را رد کرد",
      "actions": [
        {"type": "notification", "notification_type": "sms", "template": "comprehensive_application_rejected_supervision", "recipients": ["student"]}
      ]
    },
    {
      "from": "supervision_committee_review",
      "to": "supervision_committee_review",
      "trigger": "supervision_sla_breach",
      "description_fa": "۲ روز بدون بررسی — اطلاع به معاون مدیر آموزش",
      "actions": [
        {"type": "notification", "notification_type": "in_app", "template": "supervision_review_sla_breach", "recipients": ["deputy_education"]}
      ]
    },
    {
      "from": "executive_review",
      "to": "scientific_review",
      "trigger": "executive_opinion_submitted",
      "required_role": "progress_committee",
      "description_fa": "مسئول اجرایی پرونده و معدل را بررسی و نظر مشورتی ثبت کرد — ارسال به مسئول علمی",
      "actions": [
        {"type": "store_executive_advisory_opinion"},
        {"type": "notification", "notification_type": "sms", "template": "file_forwarded_to_scientific", "recipients": ["progress_committee"]}
      ]
    },
    {
      "from": "executive_review",
      "to": "executive_review",
      "trigger": "executive_sla_breach",
      "description_fa": "۲ روز بدون بررسی — اطلاع به معاون مدیر آموزش",
      "actions": [
        {"type": "notification", "notification_type": "in_app", "template": "executive_review_sla_breach", "recipients": ["deputy_education"]}
      ]
    },
    {
      "from": "scientific_review",
      "to": "document_upload",
      "trigger": "scientific_approved",
      "required_role": "progress_committee",
      "description_fa": "مسئول علمی تایید کرد — دانشجو باید گزارش تجربه شخصی بارگذاری کند",
      "actions": [
        {"type": "notification", "notification_type": "sms", "template": "approved_upload_documents", "recipients": ["student"]},
        {"type": "notification", "notification_type": "in_app", "template": "approved_upload_documents", "recipients": ["student"]}
      ]
    },
    {
      "from": "scientific_review",
      "to": "scientific_rejected",
      "trigger": "scientific_rejected",
      "required_role": "progress_committee",
      "description_fa": "مسئول علمی پرونده را رد کرد",
      "actions": [
        {"type": "notification", "notification_type": "sms", "template": "comprehensive_application_rejected_scientific", "recipients": ["student"]}
      ]
    },
    {
      "from": "scientific_review",
      "to": "scientific_review",
      "trigger": "scientific_requested_proof",
      "required_role": "progress_committee",
      "description_fa": "مسئول علمی درخواست مدرک ثبت‌نام ترم ۴ کارشناسی ارشد کرد",
      "actions": [
        {"type": "notification", "notification_type": "sms", "template": "proof_of_enrollment_required", "recipients": ["student"]}
      ]
    },
    {
      "from": "scientific_review",
      "to": "scientific_review",
      "trigger": "scientific_sla_breach",
      "description_fa": "۲ روز بدون تصمیم — نمایش هشدار در پورتال کمیته پیشرفت",
      "actions": [
        {"type": "notification", "notification_type": "in_app", "template": "scientific_review_sla_breach", "recipients": ["progress_committee"]}
      ]
    },
    {
      "from": "document_upload",
      "to": "interview_scheduled",
      "trigger": "document_uploaded",
      "required_role": "student",
      "description_fa": "دانشجو گزارش تجربه شخصی را بارگذاری کرد — انتخاب زمان مصاحبه"
    },
    {
      "from": "interview_scheduled",
      "to": "interview_payment",
      "trigger": "interview_time_selected",
      "required_role": "student",
      "description_fa": "دانشجو زمان مصاحبه (آنلاین یا حضوری) را انتخاب کرد — هدایت به پرداخت"
    },
    {
      "from": "interview_payment",
      "to": "interview_completed",
      "trigger": "interview_payment_confirmed",
      "description_fa": "پرداخت هزینه مصاحبه تایید شد — ارسال اطلاعیه مصاحبه",
      "actions": [
        {"type": "show_payment_confirmation"},
        {
          "type": "notification",
          "notification_type": "sms",
          "template": "interview_scheduled_student_online",
          "recipients": ["student"],
          "condition": "interview_type == 'online'",
          "message_fa": "مصاحبه آنلاین شما در تاریخ {interview_date} ساعت {interview_time} برگزار می‌شود. لینک: {interview_link}"
        },
        {
          "type": "notification",
          "notification_type": "sms",
          "template": "interview_scheduled_student_in_person",
          "recipients": ["student"],
          "condition": "interview_type == 'in_person'",
          "message_fa": "مصاحبه حضوری شما در تاریخ {interview_date} ساعت {interview_time} در محل انستیتو برگزار می‌شود."
        },
        {
          "type": "notification",
          "notification_type": "sms",
          "template": "interview_scheduled_interviewer",
          "recipients": ["progress_committee"]
        },
        {
          "type": "share_document_with_interviewer",
          "document": "personal_experience_report",
          "recipients": ["progress_committee"]
        },
        {
          "type": "schedule_reminder",
          "reminder_offset_hours": 2,
          "notification_type": "sms",
          "template": "interview_reminder_2h",
          "recipients": ["student", "progress_committee"]
        }
      ]
    },
    {
      "from": "interview_payment",
      "to": "interview_payment",
      "trigger": "interview_payment_failed",
      "description_fa": "پرداخت ناموفق — تلاش مجدد",
      "actions": [
        {"type": "notification", "notification_type": "sms", "template": "payment_rejected", "recipients": ["student"]}
      ]
    },
    {
      "from": "interview_completed",
      "to": "result_accepted",
      "trigger": "interview_result_accepted",
      "required_role": "progress_committee",
      "description_fa": "نتیجه مصاحبه: پذیرش — شرایط الزامی ابلاغ می‌شود",
      "actions": [
        {
          "type": "notification",
          "notification_type": "sms",
          "template": "comprehensive_accepted",
          "recipients": ["student"],
          "message_fa": "نتیجه مصاحبه: پذیرفته شدید. شرایط: درمان شخصی حداقل ۲ بار در هفته الزامی است. تمامی دروس ترم الزامی می‌باشد. ثبت‌نام برای شما فعال شد."
        }
      ]
    },
    {
      "from": "interview_completed",
      "to": "result_rejected",
      "trigger": "interview_result_rejected",
      "required_role": "progress_committee",
      "description_fa": "نتیجه مصاحبه: رد قطعی — دلایل محرمانه فقط در پورتال پذیرش ذخیره می‌شود",
      "actions": [
        {"type": "store_rejection_reason_confidential", "storage": "admissions_portal_only"},
        {
          "type": "notification",
          "notification_type": "sms",
          "template": "comprehensive_rejected_definitive",
          "recipients": ["student"]
        }
      ]
    },
    {
      "from": "interview_completed",
      "to": "result_rejected_with_suggestion",
      "trigger": "interview_result_rejected_with_suggestion",
      "required_role": "progress_committee",
      "description_fa": "نتیجه مصاحبه: رد همراه با پیشنهاد (متن دکتر مرادی) — دلایل محرمانه",
      "actions": [
        {"type": "store_rejection_reason_confidential", "storage": "admissions_portal_only"},
        {
          "type": "notification",
          "notification_type": "sms",
          "template": "comprehensive_rejected_with_suggestion",
          "recipients": ["student"],
          "message_source": "Dr. Moradi predefined text"
        }
      ]
    },
    {
      "from": "result_accepted",
      "to": "course_display",
      "trigger": "registration_opened",
      "description_fa": "سیستم تمام دروس ترم ۳ (اولین ترم جامع) را نمایش می‌دهد — تمامی دروس الزامی",
      "actions": [
        {"type": "load_term3_courses", "mandatory": true}
      ]
    },
    {
      "from": "course_display",
      "to": "payment",
      "trigger": "courses_confirmed",
      "required_role": "student",
      "description_fa": "دانشجو دروس را مشاهده و تایید کرد — هدایت به پرداخت شهریه"
    },
    {
      "from": "payment",
      "to": "registration_complete",
      "trigger": "tuition_payment_confirmed",
      "description_fa": "پرداخت شهریه تایید شد — ثبت‌نام نهایی، ایجاد لینک‌های آنلاین در LMS",
      "actions": [
        {"type": "register_student_in_courses"},
        {"type": "create_lms_course_links"},
        {"type": "notification", "notification_type": "sms", "template": "registration_complete", "recipients": ["student"]},
        {"type": "notification", "notification_type": "in_app", "template": "registration_complete", "recipients": ["student"]}
      ]
    },
    {
      "from": "payment",
      "to": "payment",
      "trigger": "tuition_payment_failed",
      "description_fa": "پرداخت ناموفق — تلاش مجدد",
      "actions": [
        {"type": "notification", "notification_type": "sms", "template": "payment_rejected", "recipients": ["student"]}
      ]
    }
  ],
  "forms": [
    {
      "code": "interview_evaluation_form",
      "name_fa": "فرم ارزیابی مصاحبه ورود به دوره جامع",
      "used_in_state": "interview_completed",
      "confidential": true,
      "note": "دلایل رد محرمانه است و فقط در پورتال پذیرش ذخیره می‌شود — هرگز به دانشجو نمایش داده نمی‌شود",
      "fields": [
        {"code": "student_name", "label_fa": "نام دانشجو", "type": "text", "readonly": true, "auto_filled": true},
        {"code": "interview_date", "label_fa": "تاریخ مصاحبه", "type": "date", "readonly": true, "auto_filled": true},
        {"code": "interview_type", "label_fa": "نوع مصاحبه", "type": "select", "options": ["آنلاین", "حضوری"], "readonly": true, "auto_filled": true},
        {
          "code": "result",
          "label_fa": "نتیجه مصاحبه",
          "type": "select",
          "required": true,
          "options": [
            {"value": "accepted", "label_fa": "پذیرش"},
            {"value": "rejected_definitive", "label_fa": "رد قطعی"},
            {"value": "rejected_with_suggestion", "label_fa": "رد همراه با پیشنهاد"}
          ]
        },
        {"code": "evaluation_notes", "label_fa": "توضیحات ارزیابی", "type": "textarea", "required": true, "confidential": true},
        {"code": "rejection_reason", "label_fa": "دلیل رد (محرمانه)", "type": "textarea", "required_if": "result != 'accepted'", "confidential": true, "visible_to": ["admissions_portal"]},
        {"code": "suggestion_text", "label_fa": "متن پیشنهاد (در صورت رد با پیشنهاد)", "type": "textarea", "required_if": "result == 'rejected_with_suggestion'", "source": "Dr. Moradi predefined text"}
      ]
    }
  ],
  "payment_config": {
    "tuition": {
      "methods": ["cash", "installments"],
      "max_installments": 4,
      "installment_schedule": {
        "first": "at_registration",
        "subsequent_interval_days": 25,
        "first_subsequent_offset_days": 25,
        "offset_from": "classes_start_date"
      },
      "reminders": {
        "before_due_days": 7,
        "notification_type": "sms",
        "template": "installment_due_reminder"
      }
    }
  }
}
