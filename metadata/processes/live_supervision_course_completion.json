{
  "process": {
    "code": "live_supervision_course_completion",
    "name_fa": "خاتمه درس سوپرویژن زنده",
    "name_en": "Live Supervision Course Completion",
    "number": 67,
    "description": "۱۵ عادی + ۳ پشت آینه؛ بسته ۱۸ جلسه؛ غیبت و پرداخت جبرانی؛ فرم پیاده‌سازی و ارزیابی؛ پایان شخصی‌سازی‌شده و ارزیابی کیفی سوال ۷ و ۸.",
    "initial_state": "grades_entry",
    "initial_role": "instructor",
    "requires_form": true
  },
  "states": [
    {"code": "grades_entry", "name_fa": "ثبت نمرات و ارزیابی", "type": "initial", "assigned_role": "instructor"},
    {"code": "grades_locked", "name_fa": "نمرات قفل شد", "type": "terminal", "assigned_role": "system"},
    {"code": "delay_reported", "name_fa": "تاخیر — گزارش به کمیته", "type": "terminal", "assigned_role": "system"}
  ],
  "transitions": [
    {"from": "grades_entry", "to": "grades_locked", "trigger": "grades_submitted", "required_role": "instructor", "conditions": ["course_grades_submitted_in_time"], "description_fa": "ثبت نمرات — قفل"},
    {"from": "grades_entry", "to": "delay_reported", "trigger": "sla_breach", "conditions": ["course_grades_sla_breach"], "description_fa": "گذشت مهلت — گزارش"}
  ],
  "forms": [
    {
      "code": "live_supervision_grades_form",
      "name_fa": "ثبت حضور و ارزیابی سوپرویژن زنده",
      "used_in_state": "grades_entry",
      "fields": [
        {"name": "course_name", "label_fa": "نام درس", "type": "readonly"},
        {
          "name": "students_grades",
          "label_fa": "لیست دانشجویان و نمرات",
          "type": "dynamic_list",
          "fields": [
            "student_name",
            "student_id",
            "grade"
          ]
        }
      ]
    }
  ]
}
