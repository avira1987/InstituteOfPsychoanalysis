{
  "process": {
    "code": "session_payment",
    "name_fa": "پرداخت برای جلسات آتی درمان آموزشی",
    "name_en": "Payment for Future Educational Therapy Sessions",
    "description": "موتور مالی جریان درمان. پیش‌شرط: جلسه اول در آغاز درمان پرداخت شده. قفل ثبت حضور تا پرداخت. شامل: داشبورد مالی (بدهکار/بستانکار/جلسه پیش‌رو)، شرط بدهی (تسویه اجباری با جلسات آتی در صورت بدهی)، پرداخت ۱ یا چند جلسه، تخصیص اعتبار به جلسات، فعال‌سازی لینک و ثبت حضور.",
    "initial_state": "payment_due"
  },
  "forms": [
    {
      "code": "session_payment_selection",
      "title_fa": "انتخاب تعداد جلسه و تسویه بدهی",
      "used_in_state": "payment_selection",
      "fields": [
        {
          "name": "sessions_to_pay",
          "label_fa": "تعداد جلسات برای پیش‌پرداخت",
          "type": "number",
          "required": true,
          "min": 1,
          "max": 52
        },
        {
          "name": "debt_settlement_included",
          "label_fa": "تسویهٔ بدهی جلسه‌های قبلی در همین پرداخت (در صورت وجود بدهی)",
          "type": "checkbox",
          "required": false
        }
      ]
    }
  ],
  "states": [
    {
      "code": "payment_due",
      "name_fa": "مبلغ قابل پرداخت",
      "type": "initial",
      "assigned_role": "student",
      "metadata": {
        "student_short_fa": "شروع پرداخت جلسات آتی",
        "student_task_fa": "دکمهٔ «ادامه به انتخاب جلسات و تسویه» را بزنید. اگر بدهی جلسهٔ قبلی دارید، در مرحلهٔ بعد آن را همراه پرداخت انتخاب کنید."
      }
    },
    {
      "code": "payment_selection",
      "name_fa": "انتخاب جلسات و تسویه بدهی",
      "type": "intermediate",
      "assigned_role": "student",
      "metadata": {
        "student_short_fa": "انتخاب تعداد جلسه و تسویه",
        "student_task_fa": "فرم همین صفحه را تکمیل کنید؛ در صورت بدهی، گزینهٔ تسویه را فعال کنید. سپس دکمهٔ «ادامه و ثبت مرحله» را بزنید تا به درگاه هدایت شوید."
      }
    },
    {
      "code": "awaiting_payment",
      "name_fa": "در انتظار پرداخت (درگاه)",
      "type": "intermediate",
      "assigned_role": "student",
      "sla_hours": 72,
      "metadata": {
        "student_short_fa": "پرداخت درگاه",
        "student_task_fa": "از بخش پرداخت سپ همین صفحه استفاده کنید. پس از بازگشت از بانک، صفحه را یک‌بار تازه کنید."
      }
    },
    {"code": "payment_confirmed", "name_fa": "پرداخت تایید شد", "type": "terminal", "assigned_role": "system"},
    {
      "code": "payment_failed",
      "name_fa": "پرداخت ناموفق",
      "type": "intermediate",
      "assigned_role": "student",
      "metadata": {
        "student_task_fa": "می‌توانید دوباره تلاش کنید یا در صورت نیاز با پشتیبانی تماس بگیرید."
      }
    },
    {"code": "session_suspended", "name_fa": "جلسات معلق", "type": "terminal", "assigned_role": "system"}
  ],
  "transitions": [
    {
      "from": "payment_due",
      "to": "payment_selection",
      "trigger": "student_initiated_payment",
      "required_role": "student",
      "description_fa": "دانشجو کلیک روی لینک پرداخت — نمایش داشبورد و گزینه‌های پرداخت"
    },
    {
      "from": "payment_selection",
      "to": "awaiting_payment",
      "trigger": "payment_selection_submitted",
      "required_role": "student",
      "conditions": ["payment_selection_valid"],
      "description_fa": "انتخاب تسویه بدهی (در صورت وجود) و جلسات آتی — هدایت به درگاه",
      "actions": [
        {"type": "generate_payment_invoice"}
      ]
    },
    {
      "from": "payment_selection",
      "to": "payment_due",
      "trigger": "selection_invalid",
      "description_fa": "در صورت بدهی، انتخاب فقط جلسات آینده مجاز نیست",
      "actions": [
        {"type": "notification", "notification_type": "sms", "template": "debt_settlement_required", "recipients": ["student"]}
      ]
    },
    {
      "from": "awaiting_payment",
      "to": "payment_confirmed",
      "trigger": "payment_successful",
      "description_fa": "پرداخت موفق — صفر کردن بدهی، افزودن به بستانکاری، تخصیص به جلسات",
      "actions": [
        {"type": "zero_debt_if_paid"},
        {"type": "add_to_credit_balance"},
        {"type": "allocate_credit_to_sessions"},
        {"type": "unlock_session_links"},
        {"type": "unlock_attendance_registration"},
        {"type": "notification", "notification_type": "sms", "template": "payment_confirmed", "recipients": ["student"]}
      ]
    },
    {
      "from": "awaiting_payment",
      "to": "payment_failed",
      "trigger": "payment_unsuccessful",
      "description_fa": "پرداخت ناموفق — امکان تلاش مجدد",
      "actions": [
        {"type": "notification", "notification_type": "sms", "template": "payment_rejected", "recipients": ["student"]}
      ]
    },
    {
      "from": "payment_failed",
      "to": "awaiting_payment",
      "trigger": "retry_payment",
      "required_role": "student",
      "description_fa": "تلاش مجدد پرداخت",
      "actions": [
        {"type": "notification", "notification_type": "sms", "template": "payment_retry", "recipients": ["student"]}
      ]
    },
    {
      "from": "payment_failed",
      "to": "session_suspended",
      "trigger": "max_retries_exceeded",
      "conditions": ["payment_max_retries_exceeded"],
      "description_fa": "تعداد تلاش بیش از حد — تعلیق جلسات",
      "actions": [
        {"type": "suspend_sessions"},
        {"type": "notification", "notification_type": "sms", "template": "sessions_suspended", "recipients": ["student", "therapist", "admin"]}
      ]
    },
    {
      "from": "awaiting_payment",
      "to": "payment_failed",
      "trigger": "payment_timeout",
      "description_fa": "مهلت پرداخت تمام شد",
      "actions": [
        {"type": "notification", "notification_type": "sms", "template": "payment_overdue", "recipients": ["student"]}
      ]
    }
  ]
}
