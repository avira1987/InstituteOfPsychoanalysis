{
  "process": {
    "code": "start_therapy",
    "name_fa": "آغاز درمان آموزشی",
    "name_en": "Start Educational Therapy",
    "description": "دروازه ورود دانشجو به درمان شخصی. فرایند یک‌بارمصرف (آشنایی و جامع هر کدام یک بار). شامل: بررسی قبلی اجرا، صلاحیت، قانون هفته نهم، انتخاب درمانگر با برنامه هفتگی (جامع ۲+/هفته، آشنایی ۱–۲/هفته)، قانون ۲۴ ساعت برای تاریخ شروع، پرداخت، ثبت، رفع محدودیت و اطلاع‌رسانی.",
    "initial_state": "eligibility_check"
  },
  "states": [
    {"code": "eligibility_check", "name_fa": "بررسی صلاحیت و یک‌بارمصرف بودن", "type": "initial", "assigned_role": "system"},
    {"code": "already_completed", "name_fa": "قبلاً انجام شده", "type": "terminal", "assigned_role": "system"},
    {
      "code": "therapist_selection",
      "name_fa": "انتخاب درمانگر و برنامه هفتگی",
      "type": "intermediate",
      "assigned_role": "student",
      "metadata": {
        "student_short_fa": "انتخاب درمانگر و تعداد جلسات هفتگی",
        "student_task_fa": "درمانگر آموزشی و برنامهٔ هفتگی (مثلاً ۲ جلسه در هفته برای دوره جامع) را در فرم زیر مشخص کنید؛ سپس دکمهٔ ادامه را بزنید تا درخواست برای درمانگر ارسال شود."
      }
    },
    {
      "code": "therapist_confirmation",
      "name_fa": "تایید درمانگر",
      "type": "intermediate",
      "assigned_role": "therapist",
      "sla_hours": 72,
      "metadata": {
        "student_short_fa": "در انتظار پاسخ درمانگر",
        "student_task_fa": "درمانگر انتخابی باید درخواست شما را در پنل خود بررسی و بپذیرد یا رد کند. لطفاً چند ساعت صبر کنید و همین صفحه را تازه کنید."
      }
    },
    {
      "code": "schedule_first_session",
      "name_fa": "تنظیم روز و ساعت جلسات",
      "type": "intermediate",
      "assigned_role": "student",
      "metadata": {
        "student_short_fa": "تاریخ شروع جلسات",
        "student_task_fa": "تاریخ شروع اولین جلسه را ثبت کنید؛ سامانه قانون ۲۴ ساعت را اعمال می‌کند و در صورت نیاز تاریخ را به هفتهٔ بعد موکول می‌کند. سپس به مرحلهٔ پرداخت هدایت می‌شوید."
      }
    },
    {
      "code": "first_session_24h_check",
      "name_fa": "محاسبه تاریخ شروع (قانون ۲۴ ساعت)",
      "type": "intermediate",
      "assigned_role": "system",
      "metadata": {
        "student_short_fa": "در حال ثبت زمان‌بندی",
        "student_task_fa": "این مرحله معمولاً به‌صورت خودکار طی چند ثانیه تکمیل می‌شود. اگر متوقف ماند، صفحه را تازه کنید."
      }
    },
    {
      "code": "payment_pending",
      "name_fa": "در انتظار پرداخت جلسه اول",
      "type": "intermediate",
      "assigned_role": "student",
      "sla_hours": 48,
      "metadata": {
        "student_short_fa": "پرداخت جلسهٔ اول",
        "student_task_fa": "هزینهٔ جلسهٔ اول را از طریق درگاه بانک همین صفحه بپردازید. پس از تأیید بانک، درمان در پروندهٔ شما فعال می‌شود و به مرحلهٔ «پرداخت جلسات آتی» هدایت می‌شوید."
      }
    },
    {"code": "therapy_active", "name_fa": "درمان فعال", "type": "terminal", "assigned_role": "system"},
    {"code": "ineligible", "name_fa": "عدم صلاحیت", "type": "terminal", "assigned_role": "system"},
    {"code": "week9_blocked", "name_fa": "مسدود - هفته نهم", "type": "terminal", "assigned_role": "system"}
  ],
  "transitions": [
    {
      "from": "eligibility_check",
      "to": "already_completed",
      "trigger": "duplicate_attempt",
      "conditions": ["already_started_therapy"],
      "description_fa": "دانشجو قبلاً این فرایند را انجام داده — پیام و پایان",
      "actions": [
        {"type": "notification", "notification_type": "sms", "template": "therapy_already_used", "recipients": ["student"]}
      ]
    },
    {
      "from": "eligibility_check",
      "to": "therapist_selection",
      "trigger": "eligible",
      "conditions": ["student_eligible_for_therapy", "therapy_not_started"],
      "description_fa": "صلاحیت تایید شد — نمایش وقت‌های آزاد درمانگران",
      "actions": [
        {"type": "notification", "notification_type": "sms", "template": "therapy_eligible", "recipients": ["student"]}
      ]
    },
    {
      "from": "eligibility_check",
      "to": "ineligible",
      "trigger": "not_eligible",
      "conditions": ["student_not_eligible"],
      "description_fa": "عدم صلاحیت",
      "actions": [
        {"type": "notification", "notification_type": "sms", "template": "therapy_ineligible", "recipients": ["student"]}
      ]
    },
    {
      "from": "eligibility_check",
      "to": "week9_blocked",
      "trigger": "week9_deadline_exceeded",
      "conditions": ["week_9_deadline"],
      "description_fa": "مهلت هفته نهم گذشته — مسدودیت کلاس آنلاین و حضور/غیاب",
      "actions": [
        {"type": "block_class_access"},
        {"type": "notification", "notification_type": "sms", "template": "week9_block", "recipients": ["student", "admin"]}
      ]
    },
    {
      "from": "therapist_selection",
      "to": "therapist_confirmation",
      "trigger": "therapist_selected",
      "required_role": "student",
      "description_fa": "دانشجو درمانگر و برنامه هفتگی را انتخاب کرد"
    },
    {
      "from": "therapist_confirmation",
      "to": "schedule_first_session",
      "trigger": "therapist_accepted",
      "required_role": "therapist",
      "description_fa": "درمانگر پذیرفت"
    },
    {
      "from": "therapist_confirmation",
      "to": "therapist_selection",
      "trigger": "therapist_declined",
      "required_role": "therapist",
      "description_fa": "درمانگر نپذیرفت",
      "actions": [
        {"type": "notification", "notification_type": "sms", "template": "therapist_declined", "recipients": ["student"]}
      ]
    },
    {
      "from": "schedule_first_session",
      "to": "first_session_24h_check",
      "trigger": "session_time_selected",
      "required_role": "student",
      "conditions": ["schedule_valid_for_course"],
      "description_fa": "برنامه هفتگی ثبت شد (جامع ۲+/هفته، آشنایی ۱–۲/هفته)",
      "actions": [
        {"type": "apply_start_therapy_session_schedule"}
      ]
    },
    {
      "from": "first_session_24h_check",
      "to": "payment_pending",
      "trigger": "24h_check_passed",
      "conditions": ["24_hour_rule"],
      "description_fa": "تاریخ اولین جلسه محاسبه شد (قانون ۲۴ ساعت)"
    },
    {
      "from": "payment_pending",
      "to": "payment_pending",
      "trigger": "payment_failed",
      "description_fa": "پرداخت ناموفق — بازگشت برای تلاش مجدد",
      "actions": [
        {"type": "notification", "notification_type": "sms", "template": "payment_rejected", "recipients": ["student"]}
      ]
    },
    {
      "from": "payment_pending",
      "to": "therapy_active",
      "trigger": "payment_confirmed",
      "description_fa": "پرداخت تایید — ثبت نهایی، رفع محدودیت، اطلاع‌رسانی",
      "actions": [
        {"type": "activate_therapy"},
        {"type": "resolve_access_restrictions"},
        {"type": "create_session_link"},
        {"type": "notification", "notification_type": "sms", "template": "therapy_scheduled_student", "recipients": ["student"]},
        {"type": "notification", "notification_type": "sms", "template": "therapy_scheduled_therapist", "recipients": ["therapist"]}
      ]
    }
  ],
  "forms": [
    {
      "code": "start_therapy_therapist_pick",
      "name_fa": "انتخاب درمانگر و برنامه هفتگی",
      "used_in_state": "therapist_selection",
      "fields": [
        {
          "name": "therapist_id",
          "label_fa": "شناسه درمانگر آموزشی (UUID)",
          "type": "text",
          "required": true,
          "description_fa": "شناسهٔ کاربر درمانگر را از پذیرش یا هماهنگی اداری دریافت کنید و بدون فاصله وارد کنید.",
          "dir": "ltr"
        },
        {
          "name": "weekly_sessions",
          "label_fa": "تعداد جلسات در هفته",
          "type": "select",
          "options": [1, 2, 3, 4, 5],
          "required": true
        }
      ]
    },
    {
      "code": "start_therapy_first_session_date",
      "name_fa": "تاریخ شروع اولین جلسه",
      "used_in_state": "schedule_first_session",
      "fields": [
        {
          "name": "first_session_date",
          "label_fa": "تاریخ اولین جلسه (میلادی)",
          "type": "date_picker",
          "required": true
        }
      ]
    }
  ]
}
