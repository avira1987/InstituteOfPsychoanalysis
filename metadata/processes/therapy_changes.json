{
  "process": {
    "code": "therapy_changes",
    "name_fa": "مدیریت تغییرات درمان آموزشی",
    "name_en": "Therapy Change Management",
    "description": "مدیریت تغییرات درمان آموزشی شامل آغاز مجدد، تغییر درمانگر و تغییر ساعت جلسات",
    "initial_state": "change_request"
  },
  "states": [
    {
      "code": "change_request",
      "name_fa": "ثبت درخواست تغییر",
      "type": "initial",
      "assigned_role": "student",
      "metadata": {
        "student_short_fa": "ثبت نوع درخواست",
        "student_task_fa": "نوع تغییر را انتخاب و دلیل کوتاه بنویسید؛ سپس یک‌بار دکمهٔ ادامه را بزنید تا درخواست به مسیر درست (کمیته یا درمانگر) برود."
      }
    },
    {
      "code": "restart_review",
      "name_fa": "بررسی آغاز مجدد",
      "type": "intermediate",
      "assigned_role": "progress_committee",
      "sla_hours": 168,
      "metadata": {
        "student_short_fa": "بررسی کمیته پیشرفت",
        "student_task_fa": "درخواست آغاز مجدد در کمیته پیشرفت در حال بررسی است؛ پس از اعلام نتیجه همین صفحه را تازه کنید."
      }
    },
    {
      "code": "therapist_change_review",
      "name_fa": "بررسی تغییر درمانگر",
      "type": "intermediate",
      "assigned_role": "progress_committee",
      "sla_hours": 168,
      "metadata": {
        "student_short_fa": "بررسی کمیته پیشرفت",
        "student_task_fa": "درخواست تغییر درمانگر در کمیته پیشرفت در حال بررسی است؛ پس از تایید، درمانگر جدید را در مرحلهٔ بعد انتخاب می‌کنید."
      }
    },
    {
      "code": "schedule_change_review",
      "name_fa": "بررسی تغییر ساعت",
      "type": "intermediate",
      "assigned_role": "therapist",
      "sla_hours": 72,
      "metadata": {
        "student_short_fa": "بررسی درمانگر",
        "student_task_fa": "درمانگر در حال بررسی پیشنهاد شما برای ساعت جلسات است."
      }
    },
    {
      "code": "new_therapist_selection",
      "name_fa": "انتخاب درمانگر جدید",
      "type": "intermediate",
      "assigned_role": "student",
      "metadata": {
        "student_short_fa": "انتخاب درمانگر جدید",
        "student_task_fa": "شناسهٔ درمانگر جدید را مطابق راهنمای انستیتو وارد کنید و تایید نهایی را بزنید."
      }
    },
    {
      "code": "new_schedule_confirmation",
      "name_fa": "تایید ساعت جدید",
      "type": "intermediate",
      "assigned_role": "student",
      "metadata": {
        "student_short_fa": "تایید ساعت جلسات",
        "student_task_fa": "ساعت پیشنهادی توسط درمانگر را بررسی کنید؛ در صورت تایید، دکمهٔ ادامه را بزنید تا ساعت روی جلسات آینده ثبت شود."
      }
    },
    {"code": "change_approved", "name_fa": "تغییر تایید شد", "type": "terminal", "assigned_role": "system"},
    {"code": "change_rejected", "name_fa": "تغییر رد شد", "type": "terminal", "assigned_role": "system"},
    {"code": "restart_activated", "name_fa": "آغاز مجدد فعال شد", "type": "terminal", "assigned_role": "system"}
  ],
  "transitions": [
    {
      "from": "change_request",
      "to": "restart_review",
      "trigger": "request_submitted",
      "required_role": "student",
      "conditions": ["change_type_is_restart"]
    },
    {
      "from": "change_request",
      "to": "therapist_change_review",
      "trigger": "request_submitted",
      "required_role": "student",
      "conditions": ["change_type_is_therapist"]
    },
    {
      "from": "change_request",
      "to": "schedule_change_review",
      "trigger": "request_submitted",
      "required_role": "student",
      "conditions": ["change_type_is_schedule"]
    },
    {
      "from": "restart_review",
      "to": "restart_activated",
      "trigger": "restart_approved",
      "required_role": "progress_committee",
      "actions": [
        {"type": "reset_therapy_sessions"},
        {"type": "notification", "notification_type": "sms", "template": "therapy_restart_approved", "recipients": ["student", "therapist"]}
      ]
    },
    {
      "from": "restart_review",
      "to": "change_rejected",
      "trigger": "restart_rejected",
      "required_role": "progress_committee",
      "actions": [
        {"type": "notification", "notification_type": "sms", "template": "change_rejected", "recipients": ["student"]}
      ]
    },
    {
      "from": "therapist_change_review",
      "to": "new_therapist_selection",
      "trigger": "therapist_change_approved",
      "required_role": "progress_committee"
    },
    {
      "from": "therapist_change_review",
      "to": "change_rejected",
      "trigger": "therapist_change_rejected",
      "required_role": "progress_committee"
    },
    {
      "from": "new_therapist_selection",
      "to": "change_approved",
      "trigger": "new_therapist_confirmed",
      "required_role": "student",
      "actions": [
        {"type": "update_therapist"},
        {"type": "notification", "notification_type": "sms", "template": "therapist_changed", "recipients": ["student", "therapist"]}
      ]
    },
    {
      "from": "schedule_change_review",
      "to": "new_schedule_confirmation",
      "trigger": "schedule_change_approved",
      "required_role": "therapist"
    },
    {
      "from": "schedule_change_review",
      "to": "change_rejected",
      "trigger": "schedule_change_rejected",
      "required_role": "therapist"
    },
    {
      "from": "new_schedule_confirmation",
      "to": "change_approved",
      "trigger": "new_schedule_confirmed",
      "required_role": "student",
      "actions": [
        {"type": "update_schedule"},
        {"type": "notification", "notification_type": "sms", "template": "schedule_changed", "recipients": ["student", "therapist"]}
      ]
    }
  ],
  "forms": [
    {
      "code": "therapy_change_request",
      "used_in_state": "change_request",
      "title_fa": "جزئیات درخواست",
      "fields": [
        {
          "name": "change_type",
          "label_fa": "نوع تغییر",
          "type": "radio",
          "required": true,
          "options": [
            {"value": "restart", "label_fa": "آغاز مجدد درمان (حذف جلسات آینده و شروع مجدد طبق مقررات)"},
            {"value": "therapist_change", "label_fa": "تغییر درمانگر آموزشی"},
            {"value": "schedule_change", "label_fa": "تغییر ساعت جلسات"}
          ]
        },
        {
          "name": "request_reason",
          "label_fa": "توضیح کوتاه / دلیل درخواست",
          "type": "textarea",
          "required": false
        }
      ]
    },
    {
      "code": "therapy_new_therapist",
      "used_in_state": "new_therapist_selection",
      "title_fa": "درمانگر جدید",
      "fields": [
        {
          "name": "new_therapist_id",
          "label_fa": "شناسهٔ کاربری (UUID) درمانگر جدید",
          "type": "text",
          "required": true
        }
      ]
    },
    {
      "code": "therapy_schedule_student_confirm",
      "used_in_state": "new_schedule_confirmation",
      "title_fa": "تایید نهایی ساعت جلسات",
      "fields": [
        {
          "name": "session_time_hhmm",
          "label_fa": "ساعت توافق‌شده برای جلسات آینده (مثال ۱۴:۳۰)",
          "type": "text",
          "required": true
        },
        {
          "name": "schedule_confirm_ack",
          "label_fa": "ساعت بالا را با درمانگر هماهنگ کرده‌ام و تایید می‌کنم",
          "type": "radio",
          "required": true,
          "options": [
            {"value": "yes", "label_fa": "تایید می‌کنم"}
          ]
        }
      ]
    }
  ]
}
