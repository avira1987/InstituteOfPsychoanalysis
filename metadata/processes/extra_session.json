{
  "process": {
    "code": "extra_session",
    "name_fa": "برگزاری جلسه اضافی درمان آموزشی",
    "name_en": "Extra Educational Therapy Session",
    "description": "انعطاف‌پذیری کنترل‌شده برای جلسات فوق‌العاده. توافق دوجانبه پیش از پرداخت. شامل: ثبت درخواست (تاریخ/ساعت هفته جاری یا آتی)، ارجاع به درمانگر با SMS، تصمیم درمانگر (تایید / رد+پیشنهاد جایگزین با سیکل مذاکره / عدم امکان)، پرداخت، ثبت در تقویم، لینک آنلاین، SMS تایید و ثبت در SOP پر شدن ساعات.",
    "initial_state": "extra_request"
  },
  "states": [
    {"code": "extra_request", "name_fa": "ثبت درخواست جلسه اضافی", "type": "initial", "assigned_role": "student", "metadata": {"student_short_fa": "درخواست زمان جلسه اضافی", "student_task_fa": "تاریخ و ساعت پیشنهادی خود را در فرم همین صفحه وارد و ثبت کنید؛ سپس دکمهٔ ادامه را بزنید تا درمانگر بررسی کند."}},
    {"code": "therapist_review", "name_fa": "بررسی و تصمیم درمانگر", "type": "intermediate", "assigned_role": "therapist", "sla_hours": 48, "metadata": {"student_short_fa": "منتظر درمانگر", "student_task_fa": "درمانگر زمان شما را بررسی می‌کند؛ اگر پیامک یا اعلان دریافت کردید طبق آن عمل کنید؛ بعداً همین صفحه را تازه کنید."}},
    {"code": "student_response", "name_fa": "پاسخ دانشجو به پیشنهاد جایگزین", "type": "intermediate", "assigned_role": "student", "metadata": {"student_short_fa": "پاسخ به زمان پیشنهادی درمانگر", "student_task_fa": "اگر زمان پیشنهادی درمانگر را می‌پذیرید، تاریخ و ساعت را در فرم تأیید کنید؛ در غیر این صورت زمان جدید پیشنهاد دهید و ثبت کنید."}},
    {"code": "payment_required", "name_fa": "پرداخت جلسه اضافی", "type": "intermediate", "assigned_role": "student", "sla_hours": 48, "metadata": {"student_short_fa": "پرداخت", "student_task_fa": "ابتدا از بخش پرداخت درگاه همین صفحه مبلغ جلسه اضافی را بپردازید؛ پس از تأیید بانک، مرحلهٔ بعد به‌صورت خودکار ثبت می‌شود."}},
    {"code": "extra_session_confirmed", "name_fa": "جلسه اضافی تایید و ثبت شد", "type": "intermediate", "assigned_role": "system", "metadata": {"student_short_fa": "جلسه ثبت شد", "student_task_fa": "جلسه در سیستم ثبت شده است؛ لینک جلسه در همین مسیر یا پیامک آمده است. در زمان مقرر حاضر شوید."}},
    {"code": "extra_session_completed", "name_fa": "جلسه اضافی برگزار شد", "type": "terminal", "assigned_role": "therapist"},
    {"code": "extra_session_cancelled", "name_fa": "جلسه اضافی لغو شد", "type": "terminal", "assigned_role": "system"},
    {"code": "extra_request_rejected", "name_fa": "درخواست رد شد", "type": "terminal", "assigned_role": "system"}
  ],
  "forms": [
    {
      "id": "extra_session_request",
      "used_in_state": "extra_request",
      "title_fa": "زمان پیشنهادی جلسه اضافی",
      "visible_to": ["student"],
      "fields": [
        {"name": "preferred_date", "label_fa": "تاریخ پیشنهادی (میلادی YYYY-MM-DD)", "type": "text", "required": true},
        {"name": "preferred_time", "label_fa": "ساعت پیشنهادی (مثلاً ۱۴:۳۰ یا 14:30)", "type": "text", "required": true},
        {"name": "request_note", "label_fa": "توضیح کوتاه (اختیاری)", "type": "textarea", "required": false}
      ]
    },
    {
      "id": "extra_session_student_response",
      "used_in_state": "student_response",
      "title_fa": "تأیید یا تغییر زمان",
      "visible_to": ["student"],
      "fields": [
        {"name": "confirmed_alternative_date", "label_fa": "تاریخ تأییدشده یا جدید (YYYY-MM-DD)", "type": "text", "required": false},
        {"name": "confirmed_alternative_time", "label_fa": "ساعت تأییدشده یا جدید", "type": "text", "required": false},
        {"name": "new_preferred_date", "label_fa": "اگر زمان دیگری می‌خواهید: تاریخ جدید", "type": "text", "required": false},
        {"name": "new_preferred_time", "label_fa": "اگر زمان دیگری می‌خواهید: ساعت جدید", "type": "text", "required": false}
      ]
    }
  ],
  "transitions": [
    {
      "from": "extra_request",
      "to": "therapist_review",
      "trigger": "extra_requested",
      "required_role": "student",
      "description_fa": "دانشجو تاریخ و ساعت مدنظر را وارد کرد — ارسال به کارتابل درمانگر",
      "actions": [
        {"type": "notification", "notification_type": "sms", "template": "extra_session_request", "recipients": ["therapist"]}
      ]
    },
    {
      "from": "therapist_review",
      "to": "payment_required",
      "trigger": "therapist_approved",
      "required_role": "therapist",
      "description_fa": "درمانگر زمان پیشنهادی را تایید کرد — هدایت دانشجو به پرداخت",
      "actions": [
        {"type": "prepare_extra_session_payment"},
        {"type": "notification", "notification_type": "sms", "template": "extra_session_approved_payment", "recipients": ["student"]}
      ]
    },
    {
      "from": "therapist_review",
      "to": "student_response",
      "trigger": "therapist_proposed_alternative",
      "required_role": "therapist",
      "description_fa": "درمانگر زمان را رد و زمان جایگزین پیشنهاد کرد",
      "actions": [
        {"type": "notification", "notification_type": "sms", "template": "extra_session_alternative_proposed", "recipients": ["student"]}
      ]
    },
    {
      "from": "therapist_review",
      "to": "extra_request_rejected",
      "trigger": "therapist_unavailable",
      "required_role": "therapist",
      "description_fa": "درمانگر امکان برگزاری ندارد",
      "actions": [
        {"type": "notification", "notification_type": "sms", "template": "extra_session_rejected", "recipients": ["student"]}
      ]
    },
    {
      "from": "student_response",
      "to": "payment_required",
      "trigger": "student_confirmed_alternative",
      "required_role": "student",
      "description_fa": "دانشجو زمان پیشنهادی درمانگر را تایید کرد",
      "actions": [
        {"type": "prepare_extra_session_payment"},
        {"type": "notification", "notification_type": "sms", "template": "extra_session_approved_payment", "recipients": ["student"]}
      ]
    },
    {
      "from": "student_response",
      "to": "extra_request",
      "trigger": "student_reentered_time",
      "required_role": "student",
      "description_fa": "دانشجو زمان دیگری وارد کرد — بازگشت به درمانگر برای تایید",
      "actions": [
        {"type": "sync_extra_session_reenter_fields"}
      ]
    },
    {
      "from": "payment_required",
      "to": "extra_session_confirmed",
      "trigger": "payment_completed",
      "description_fa": "پرداخت موفق — ثبت در تقویم، لینک آنلاین، SMS تایید",
      "actions": [
        {"type": "create_extra_session_record"},
        {"type": "note_extra_session_calendar"},
        {"type": "create_session_link"},
        {"type": "notification", "notification_type": "sms", "template": "extra_session_confirmed", "recipients": ["student", "therapist"]}
      ]
    },
    {
      "from": "payment_required",
      "to": "payment_required",
      "trigger": "payment_failed",
      "description_fa": "پرداخت ناموفق — تلاش مجدد",
      "actions": [
        {"type": "notification", "notification_type": "sms", "template": "payment_rejected", "recipients": ["student"]}
      ]
    },
    {
      "from": "payment_required",
      "to": "extra_session_cancelled",
      "trigger": "payment_timeout",
      "description_fa": "مهلت پرداخت تمام شد",
      "actions": [
        {"type": "notification", "notification_type": "sms", "template": "extra_session_payment_timeout", "recipients": ["student"]}
      ]
    },
    {
      "from": "extra_session_confirmed",
      "to": "extra_session_completed",
      "trigger": "session_held",
      "required_role": "therapist",
      "description_fa": "جلسه برگزار شد — ثبت در SOP پر شدن ساعات",
      "actions": [
        {"type": "record_attendance"},
        {"type": "add_extra_session_therapy_hours"}
      ]
    },
    {
      "from": "extra_session_confirmed",
      "to": "extra_session_cancelled",
      "trigger": "session_cancelled",
      "description_fa": "جلسه لغو شد",
      "actions": [
        {"type": "process_refund"},
        {"type": "notification", "notification_type": "sms", "template": "extra_session_cancelled", "recipients": ["student", "therapist"]}
      ]
    }
  ]
}
