[
  {
    "code": "is_intern",
    "name_fa": "آیا دانشجو انترن است",
    "rule_type": "condition",
    "expression": {"field": "student.is_intern", "operator": "eq", "value": true}
  },
  {
    "code": "is_not_intern",
    "name_fa": "آیا دانشجو انترن نیست",
    "rule_type": "condition",
    "expression": {"field": "student.is_intern", "operator": "eq", "value": false}
  },
  {
    "code": "leave_terms_eq_1",
    "name_fa": "وقفه ۱ ترمی",
    "rule_type": "condition",
    "expression": {"field": "instance.leave_terms", "operator": "eq", "value": 1}
  },
  {
    "code": "leave_terms_eq_2",
    "name_fa": "وقفه ۲ ترمی",
    "rule_type": "condition",
    "expression": {"field": "instance.leave_terms", "operator": "eq", "value": 2}
  },
  {
    "code": "student_eligible_for_therapy",
    "name_fa": "صلاحیت دانشجو برای درمان",
    "rule_type": "condition",
    "expression": {
      "operator": "and",
      "conditions": [
        {"field": "student.course_type", "operator": "in", "value": ["comprehensive", "introductory"]},
        {"field": "student.term_count", "operator": "gte", "value": 1}
      ]
    }
  },
  {
    "code": "student_not_eligible",
    "name_fa": "عدم صلاحیت دانشجو",
    "rule_type": "condition",
    "expression": {
      "operator": "or",
      "conditions": [
        {"field": "student.term_count", "operator": "lt", "value": 1},
        {"field": "student.is_suspended", "operator": "eq", "value": true}
      ]
    }
  },
  {
    "code": "week_9_deadline",
    "name_fa": "قانون هفته نهم - دوره جامع",
    "rule_type": "validation",
    "expression": {
      "operator": "and",
      "conditions": [
        {"field": "student.course_type", "operator": "eq", "value": "comprehensive"},
        {"field": "student.therapy_started", "operator": "eq", "value": false},
        {"field": "instance.current_week", "operator": "gt", "value": 9}
      ]
    },
    "error_message_fa": "مهلت آغاز درمان آموزشی (هفته نهم) برای دوره جامع به پایان رسیده است"
  },
  {
    "code": "24_hour_rule",
    "name_fa": "قانون ۲۴ ساعت",
    "rule_type": "computation",
    "expression": {
      "if": {"field": "instance.hours_until_first_slot", "operator": "lt", "value": 24},
      "then": "use_next_slot",
      "else": "use_first_slot"
    }
  },
  {
    "code": "absence_quota",
    "name_fa": "سهمیه غیبت مجاز سالانه",
    "rule_type": "computation",
    "expression": {
      "formula": "ceil(student_weekly_sessions * 3)",
      "reset_cycle": "shamsi_year"
    }
  },
  {
    "code": "absence_quota_not_exceeded",
    "name_fa": "سهمیه غیبت تمام نشده",
    "rule_type": "condition",
    "expression": {"field": "instance.absences_this_year", "operator": "lt", "value": "instance.absence_quota"}
  },
  {
    "code": "absence_quota_exceeded",
